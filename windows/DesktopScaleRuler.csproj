<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>DesktopScaleRuler</AssemblyName>
    <RootNamespace>DesktopScaleRuler</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>icon.ico</ApplicationIcon>
    <Version>1.0.0</Version>
    <!-- Lets the Windows/WPF project build on any host OS (CI, Linux, macOS) -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <!-- DPI is set via app.manifest on purpose; silence the WinForms analyzer hint -->
    <NoWarn>$(NoWarn);WFAC010</NoWarn>
  </PropertyGroup>

  <!-- embed the icon so the tray can load it at runtime -->
  <ItemGroup>
    <EmbeddedResource Include="icon.ico">
      <LogicalName>icon.ico</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
